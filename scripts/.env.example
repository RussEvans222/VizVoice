# Tableau Server Configuration
# Copy this file to .env and fill in your credentials

# Tableau Server URL (e.g., https://tableau.yourcompany.com or https://your-pod.online.tableau.com)
TABLEAU_SERVER_URL=https://orgfarm-aac260ab62-dev-ed.my.salesforce.com

# Personal Access Token (create at: User Menu → My Account Settings → Personal Access Tokens)
TABLEAU_TOKEN_NAME=your_token_name
TABLEAU_TOKEN_VALUE=your_token_secret_value

# Site ID (leave empty for default site, or specify site name like "marketing" or "sales")
TABLEAU_SITE_ID=

# SAFETY NOTES:
# - This script downloads, modifies, and can re-upload your Tableau workbook
# - BACKUP your workbook before running (download a copy from Tableau Server)
# - Test on a non-production copy first
# - Review the changes locally before uploading back to the server
